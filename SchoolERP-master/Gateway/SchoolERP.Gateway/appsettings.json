{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  // 🎯 CORS WHITELIST CONFIGURATION (Add your front-end URLs here)
  "CorsSettings": {
    "AllowedOrigins": [
      "https://localhost:3000",
      "http://localhost:3000",
      "https://widen-finalize-sheath.ngrok-free.dev"
    ]
  },

  "ConnectionStrings": {
    "RedisConnection": "localhost:6379"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "student-route": {
        "ClusterId": "student-cluster",
        "Match": { "Path": "/api/student/{**catch-all}" }
      },
      "exam-route": {
        "ClusterId": "exam-cluster",
        "Match": { "Path": "/api/exam/{**catch-all}" }
      },
      "finance-route": {
        "ClusterId": "finance-cluster",
        "Match": { "Path": "/api/finance/{**catch-all}" }
      },
      "lookup-route": {
        "ClusterId": "lookup-cluster",
        "Match": { "Path": "/api/lookup/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-v1": { "Address": "https://auth-api" } // 🎯 FIXED: Changed to https://
        }
      },
      "student-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:02",
            "Path": "/api/health"
          }
        },
        "Destinations": {
          "student-v1": { "Address": "https://student-api" } // 🎯 FIXED: Changed to https://
        }
      },
      "exam-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "exam-v1": { "Address": "https://exam-api" } // 🎯 FIXED: Changed to https://
        }
      },
      "finance-cluster": {
        "Destinations": {
          "finance-v1": { "Address": "https://finance-api" } // 🎯 FIXED: Changed to https://
        }
      },
      "lookup-cluster": {
        "Destinations": {
          "lookup-v1": { "Address": "https://lookup-api" } // 🎯 FIXED: Changed to https://
        }
      }
    }
  }
}